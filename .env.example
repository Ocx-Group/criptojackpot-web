# ===========================================
# Environment Variables for CryptoJackpot App
# ===========================================

# API Configuration
# URL base unificada para todos los microservicios
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# ===========================================
# Keycloak Configuration (Public Client)
# ===========================================
# URL base del servidor Keycloak
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:30180

# Nombre del Realm en Keycloak
NEXT_PUBLIC_KEYCLOAK_REALM=cryptojackpot

# Client ID para el frontend (debe ser un cliente PUBLIC en Keycloak)
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=cryptojackpot-frontend

# ===========================================
# DEPRECATED - Next-Auth Configuration
# ===========================================
# These are no longer needed with keycloak-js direct integration.
# The frontend now uses keycloak-js directly with the public client (cryptojackpot-frontend).
# See src/lib/keycloak.ts for the current implementation.

# KEYCLOAK_CLIENT_ID=cryptojackpot-backend
# KEYCLOAK_CLIENT_SECRET=your-client-secret
# KEYCLOAK_ISSUER=http://auth.cryptojackpot.local:30180/realms/cryptojackpot
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-nextauth-secret
